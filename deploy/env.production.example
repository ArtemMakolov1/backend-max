# This file is documentation only. GitHub Actions creates .env.production.next
# from the protected production environment; do not copy real secrets here.
POSTGRES_DB=maxstudio
POSTGRES_OWNER_USER=maxstudio_owner
POSTGRES_OWNER_PASSWORD=replace_with_a_separate_32_plus_character_url_safe_secret
POSTGRES_APP_USER=maxstudio_app
POSTGRES_APP_PASSWORD=replace_with_another_32_plus_character_url_safe_secret
POSTGRES_MONITOR_USER=maxstudio_monitor
POSTGRES_MONITOR_PASSWORD=replace_with_a_third_32_plus_character_url_safe_secret
PGBOUNCER_DEFAULT_POOL_SIZE=20
PGBOUNCER_MIN_POOL_SIZE=2
PGBOUNCER_RESERVE_POOL_SIZE=5
PGBOUNCER_MAX_CLIENT_CONN=200
PUBLIC_BASE_URL=https://maxposty.ru
FRONTEND_ORIGIN=https://maxposty.ru
GRAFANA_ROOT_URL=https://maxposty.ru/monitoring/
GRAFANA_ADMIN_PASSWORD=replace_with_a_separate_32_plus_character_url_safe_secret
GRAFANA_SECRET_KEY=replace_with_another_32_plus_character_url_safe_secret
ALERTMANAGER_WEBHOOK_URL=https://alerts.example.invalid/private-receiver
AUTH_BOOTSTRAP_MODE=false
YANDEX_CLIENT_ID=replace_me
YANDEX_CLIENT_SECRET=replace_me
YANDEX_REDIRECT_URI=https://maxposty.ru/api/v1/auth/yandex/callback
YANDEX_ALLOWED_USERS=
OBSERVABILITY_ADMIN_USERS=replace_with_operator_yandex_login
AUTH_SESSION_TTL=12h
OAUTH_TRUST_X_REAL_IP=true
OAUTH_RATE_LIMIT_AT_EDGE=false
MAX_API_BASE_URL=https://platform-api2.max.ru
MAX_BOT_TOKEN=replace_with_a_fresh_token
MAX_WEBHOOK_SECRET=replace_with_a_32_plus_character_url_safe_secret
MAX_WEBHOOK_URL=https://maxposty.ru/api/v1/webhooks/max
MAX_CA_CERT_FILE=
# Private S3-compatible object storage. Host and both keys are required in
# production. Bucket may stay empty only when the key can list exactly one
# bucket; region may stay empty when it is encoded in the HOSTKEY endpoint.
S3_HOST=https://s3.example.invalid
S3_ACCESS_KEY=replace_with_s3_access_key
S3_SECRET_KEY=replace_with_s3_secret_key
S3_BUCKET=
S3_REGION=
# Limit one tenant before upload and remove abandoned objects asynchronously.
MEDIA_USER_MAX_FILES=500
MEDIA_USER_MAX_BYTES=1073741824
MEDIA_ORPHAN_GRACE_PERIOD=24h
MEDIA_CLEANUP_INTERVAL=15m
MEDIA_CLEANUP_BATCH_SIZE=50
# Optional: leave empty to run OAuth and MAX while AI routes return HTTP 503.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_RESEARCH_MODEL=gpt-5.4-mini
AI_GLOBAL_MAX_CONCURRENT=4
AI_USER_MAX_CONCURRENT=1
AI_IMAGE_PER_MINUTE=2
AI_IMAGE_PER_DAY=20
AI_RESEARCH_PER_MINUTE=2
AI_RESEARCH_PER_DAY=20
AI_LEASE_TTL=4m
SCHEDULER_INTERVAL=15s
BACKUP_RETENTION_DAYS=14
PITR_RETENTION_DAYS=7

HOST=127.0.0.1
PORT=8080
DATABASE_PATH=./data/maxpilot.db
MEDIA_DIR=./media
PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:4321

# Optional break-glass/CLI access. Authentication is fail-closed by default.
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=
# Only for an intentionally unauthenticated loopback development server.
ALLOW_INSECURE_NO_AUTH=false
# Trust nginx's X-Real-IP only when direct access to the Go port is blocked.
OAUTH_TRUST_X_REAL_IP=false
# Disable the low backend per-IP limit only when a trusted TLS edge enforces it.
OAUTH_RATE_LIMIT_AT_EDGE=false

# Yandex ID OAuth for local backend development. The Redirect URI must be
# registered exactly in the Yandex OAuth application.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
# Local example: http://localhost:8080/api/v1/auth/yandex/callback
YANDEX_REDIRECT_URI=
# Comma-separated exact Yandex user IDs, logins or email addresses.
YANDEX_ALLOWED_USERS=
AUTH_SESSION_TTL=12h

MAX_API_BASE_URL=https://platform-api2.max.ru
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
# Optional PEM certificate bundle appended to the system roots. MAX requires
# trusting the MinTsifry certificate chain for platform-api2.max.ru by 2026-07-19.
MAX_CA_CERT_FILE=

OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_RESEARCH_MODEL=gpt-5.4-mini

SCHEDULER_INTERVAL=15s

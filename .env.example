# PostgreSQL. Generate both passwords separately with: openssl rand -hex 32
POSTGRES_DB=maxstudio
POSTGRES_OWNER_USER=maxstudio_owner
POSTGRES_OWNER_PASSWORD=
POSTGRES_APP_USER=maxstudio_app
POSTGRES_APP_PASSWORD=
POSTGRES_MONITOR_USER=maxstudio_monitor
POSTGRES_MONITOR_PASSWORD=

# PgBouncer transaction pool. Keep the total below PostgreSQL max_connections.
PGBOUNCER_DEFAULT_POOL_SIZE=20
PGBOUNCER_MIN_POOL_SIZE=2
PGBOUNCER_RESERVE_POOL_SIZE=5
PGBOUNCER_MAX_CLIENT_CONN=200

# These URLs are assembled by Docker Compose. Set them manually only when
# running the Go binaries or tests outside Compose.
DATABASE_URL=
DIRECT_DATABASE_URL=
TEST_DATABASE_URL=

MEDIA_DIR=./media
PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:4321
BACKEND_PORT=8080

# Local Grafana is bound only to 127.0.0.1. Generate both secrets separately
# with `openssl rand -hex 32`. Production uses Yandex-authenticated proxy access.
GRAFANA_PORT=3000
GRAFANA_ROOT_URL=http://localhost:3000/
GRAFANA_ADMIN_PASSWORD=
GRAFANA_SECRET_KEY=
GRAFANA_SERVE_FROM_SUB_PATH=false
GRAFANA_AUTH_PROXY_ENABLED=false
GRAFANA_BASIC_AUTH_ENABLED=true
GRAFANA_COOKIE_SECURE=false

# Yandex ID is the only user-facing authentication method and is mandatory.
AUTH_BOOTSTRAP_MODE=false
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:8080/api/v1/auth/yandex/callback
# Optional private-beta allowlist: exact Yandex IDs, logins or emails, CSV.
# Leave empty to accept every successfully authenticated Yandex account.
YANDEX_ALLOWED_USERS=
# Exact Yandex logins or effective IDs (PSUID) allowed to open /monitoring/, CSV.
OBSERVABILITY_ADMIN_USERS=
AUTH_SESSION_TTL=12h
# Retained team workspaces per owner. Archived workspaces still count because
# their media quota and stored objects remain allocated.
WORKSPACE_MAX_OWNED_TEAM_WORKSPACES=5
# Trust proxy headers only when direct access to the Go port is blocked.
OAUTH_TRUST_X_REAL_IP=false
OAUTH_RATE_LIMIT_AT_EDGE=false

# Optional workspace-scoped Yandex Direct integration. These credentials and
# encryption key are independent from Yandex ID login. Configure all four
# OAuth/token values together. Generate DIRECT_TOKEN_DATA_KEY once with:
# openssl rand -base64 32
DIRECT_OAUTH_CLIENT_ID=
DIRECT_OAUTH_CLIENT_SECRET=
# API/debugging OAuth apps: https://oauth.yandex.ru/verification_code
# Web OAuth apps may instead use exactly:
# https://maxposty.ru/api/v1/advertising/direct/oauth/callback
DIRECT_OAUTH_REDIRECT_URI=
DIRECT_TOKEN_DATA_KEY=
# Sandbox and all spend-capable writes are fail-closed by default.
DIRECT_SANDBOX=true
DIRECT_API_BASE_URL=https://api-sandbox.direct.yandex.com/json/v5
DIRECT_WRITES_ENABLED=false
DIRECT_AUTO_LAUNCH_ENABLED=false

# One shared MAX bot for all accounts. Never put its token in the frontend.
MAX_API_BASE_URL=https://platform-api2.max.ru
MAX_BOT_TOKEN=
# Generate with openssl rand -hex 32 and use the same value in the MAX webhook.
MAX_WEBHOOK_SECRET=
# Public HTTPS endpoint on implicit port 443. Used only by the operator command.
MAX_WEBHOOK_URL=
# Before 19 July 2026 verify that the runtime trusts the new MAX certificate
# chain. If the system trust store does not, append the verified official PEM.
# In Compose this path must point inside ./certs mounted at /app/certs.
MAX_CA_CERT_FILE=

# Private S3-compatible storage. Leave all values empty for the local
# filesystem. Production requires host, access key and secret key;
# bucket and region are optional when the provider supports auto-discovery.
S3_HOST=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=

# Per-user media quota is reserved atomically before any object is written.
# Unreferenced and interrupted uploads are removed after the grace period.
MEDIA_USER_MAX_FILES=500
MEDIA_USER_MAX_BYTES=10737418240
MEDIA_ORPHAN_GRACE_PERIOD=24h
MEDIA_CLEANUP_INTERVAL=15m
MEDIA_CLEANUP_BATCH_SIZE=50

# Optional. Without it the server stays healthy and AI routes return HTTP 503.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_RESEARCH_MODEL=gpt-5.4-mini

# Защита общего OpenAI-аккаунта от случайных расходов и массовых запросов.
# Оба маршрута генерации изображений используют один общий image-лимит.
AI_GLOBAL_MAX_CONCURRENT=4
AI_USER_MAX_CONCURRENT=1
AI_IMAGE_PER_MINUTE=2
AI_IMAGE_PER_DAY=20
AI_RESEARCH_PER_MINUTE=2
AI_RESEARCH_PER_DAY=20
# Должен быть больше таймаута AI-обработчика (3m), чтобы зависший запрос не
# освободил место до завершения; после сбоя lease истечёт автоматически.
AI_LEASE_TTL=4m
# Observe-only by default. Set true only after billing telemetry is validated.
BILLING_ENFORCEMENT_ENABLED=false
BILLING_LIVE_ENABLED=false
# Keep false until YooKassa support confirms the current NPD receipt flow.
YOOKASSA_RECEIPTS_CONFIRMED=false

# YooKassa recurring subscriptions. Configure all three together. Generate the
# data key once with: openssl rand -base64 32
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_DATA_KEY=
YOOKASSA_RETURN_URL=https://maxposty.ru/app/?billing=pending#/workspace/settings/plan

SCHEDULER_INTERVAL=15s

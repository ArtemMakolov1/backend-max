# PostgreSQL. Generate both passwords separately with: openssl rand -hex 32
POSTGRES_DB=maxstudio
POSTGRES_OWNER_USER=maxstudio_owner
POSTGRES_OWNER_PASSWORD=
POSTGRES_APP_USER=maxstudio_app
POSTGRES_APP_PASSWORD=

# PgBouncer transaction pool. Keep the total below PostgreSQL max_connections.
PGBOUNCER_DEFAULT_POOL_SIZE=20
PGBOUNCER_MIN_POOL_SIZE=2
PGBOUNCER_RESERVE_POOL_SIZE=5
PGBOUNCER_MAX_CLIENT_CONN=200

# These URLs are assembled by Docker Compose. Set them manually only when
# running the Go binaries or tests outside Compose.
DATABASE_URL=
DIRECT_DATABASE_URL=
TEST_DATABASE_URL=

MEDIA_DIR=./media
PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:4321
BACKEND_PORT=8080

# Yandex ID is the only user-facing authentication method and is mandatory.
AUTH_BOOTSTRAP_MODE=false
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:8080/api/v1/auth/yandex/callback
# Optional private-beta allowlist: exact Yandex IDs, logins or emails, CSV.
# Leave empty to accept every successfully authenticated Yandex account.
YANDEX_ALLOWED_USERS=
AUTH_SESSION_TTL=12h
# Trust proxy headers only when direct access to the Go port is blocked.
OAUTH_TRUST_X_REAL_IP=false
OAUTH_RATE_LIMIT_AT_EDGE=false

# One shared MAX bot for all accounts. Never put its token in the frontend.
MAX_API_BASE_URL=https://platform-api2.max.ru
MAX_BOT_TOKEN=
# Generate with openssl rand -hex 32 and use the same value in the MAX webhook.
MAX_WEBHOOK_SECRET=
# Public HTTPS endpoint on implicit port 443. Used only by the operator command.
MAX_WEBHOOK_URL=
# Before 19 July 2026 verify that the runtime trusts the new MAX certificate
# chain. If the system trust store does not, append the verified official PEM.
# In Compose this path must point inside ./certs mounted at /app/certs.
MAX_CA_CERT_FILE=

# Optional. Without it the server stays healthy and AI routes return HTTP 503.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_RESEARCH_MODEL=gpt-5.4-mini

# Защита общего OpenAI-аккаунта от случайных расходов и массовых запросов.
# Оба маршрута генерации изображений используют один общий image-лимит.
AI_GLOBAL_MAX_CONCURRENT=4
AI_USER_MAX_CONCURRENT=1
AI_IMAGE_PER_MINUTE=2
AI_IMAGE_PER_DAY=20
AI_RESEARCH_PER_MINUTE=2
AI_RESEARCH_PER_DAY=20
# Должен быть больше таймаута AI-обработчика (3m), чтобы зависший запрос не
# освободил место до завершения; после сбоя lease истечёт автоматически.
AI_LEASE_TTL=4m

SCHEDULER_INTERVAL=15s
